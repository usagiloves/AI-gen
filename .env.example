# === Server ===
PORT=3000
HOST=localhost

# === Gemini ===
GEMINI_URL=https://gemini.google.com/app

# === Paths (relative to project root) ===
TEMP_VIDEO_DIR=temp_videos
COOKIE_PATH=cookies/state.json
PROMPT_PHASE_1_DIR=prompt_phase_1
PROMPT_PHASE_2_DIR=prompt_phase_2
PROMPT_KB_FILE=Prompt KB.txt

# === Browser Agent ===
HEADLESS=true
TYPING_DELAY_MIN=30
TYPING_DELAY_MAX=80
ACTION_DELAY_MIN=1000
ACTION_DELAY_MAX=3000

# === Downloader ===
YTDLP_PATH=yt-dlp
DOWNLOAD_TIMEOUT=120000

# === Logging ===
LOG_LEVEL=info
